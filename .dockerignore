# ── Python artefacts ──────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/

# ── Virtual environments ──────────────────────────────────────
.venv/
venv/
env/

# ── Test & coverage output ────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Type-checker cache ────────────────────────────────────────
.mypy_cache/

# ── Build artefacts ───────────────────────────────────────────
build/
dist/

# ── Git ───────────────────────────────────────────────────────
.git/
.gitignore

# ── IDE / editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── OS metadata ───────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── CI/CD helper files (not needed inside image) ─────────────
.github/
run_pipeline.sh
*.md
Jenkinsfile
sonar-project.properties
jenkins/

# ── Test files (never go in production image) ─────────────────
tests/
reports/
.coverage
*.xml

# ── Dev virtual environments ──────────────────────────────────
.venv-jenkins/

# ── Full dev requirements (only runtime deps go in image) ─────
requirements.txt

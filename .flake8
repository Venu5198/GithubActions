[flake8]
max-line-length = 100
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    *.egg-info
extend-ignore =
    # E203: whitespace before ':' (Black-compatible)
    E203,
    # W503: line break before binary operator
    W503
per-file-ignores =
    # Allow assert statements in tests
    tests/*:S101
